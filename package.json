{
  "name": "cli-to-mcp",
  "version": "0.1.0",
  "description": "Expose local CLIs as MCP tools over HTTP (Streamable MCP).",
  "type": "module",
  "license": "MIT",
  "author": "ZeroPointSix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZeroPointSix/cli-to-mcp.git"
  },
  "homepage": "https://github.com/ZeroPointSix/cli-to-mcp#readme",
  "bugs": {
    "url": "https://github.com/ZeroPointSix/cli-to-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "github-cli",
    "git",
    "automation",
    "agent"
  ],
  "bin": {
    "cli-to-mcp": "dist/cli/main.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node --experimental-sqlite dist/cli/main.js",
    "test": "node --experimental-sqlite node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-sqlite node_modules/vitest/vitest.mjs",
    "prepublishOnly": "npm run build && npm test",
    "test:all": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
